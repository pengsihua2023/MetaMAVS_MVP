# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS files
.DS_Store
Thumbs.db

# Run outputs (generated)
reports/*/logs/
reports/*/intermediate/
reports/*/commands/
reports/*/tables/
reports/*/state.json

# PPT build artifacts (keep build.js; exclude node deps and duplicate output)
ppt_build/node_modules/
ppt_build/package-lock.json
ppt_build/*.pptx
*.pdf
slide-*.jpg

# Stray tool-output files dropped at repo root (comparisons, scratch)
/*.tsv
/*.full.tsv

# Secrets (LLM API keys) — never commit
.env
.env.local
